rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection:
    // - Users can read their own document.
    // - Users can CREATE their own document (with role defaulting to 'user').
    // - Only admins can UPDATE (change role) or DELETE.
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId
        && request.resource.data.role == 'user';
      allow update, delete: if isAdmin();
    }

    // Business collections: only admins can read and write
    match /inventory/{document} {
      allow read, write: if isAdmin();
    }
    match /sales/{document} {
      allow read, write: if isAdmin();
    }
    match /employees/{document} {
      allow read, write: if isAdmin();
    }
    match /payroll/{document} {
      allow read, write: if isAdmin();
    }

    // Settings: only admins can read and write
    match /settings/{document} {
      allow read, write: if isAdmin();
    }
  }
}
