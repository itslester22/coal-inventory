rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection:
    // - Anyone can read/write their own document if they are authenticated and it matches their UID.
    // - Admins can read/write all user documents.
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Business collections: only admins can read and write
    match /inventory/{document} {
      allow read, write: if isAdmin();
    }
    match /sales/{document} {
      allow read, write: if isAdmin();
    }
    match /employees/{document} {
      allow read, write: if isAdmin();
    }
    match /payroll/{document} {
      allow read, write: if isAdmin();
    }
  }
}
